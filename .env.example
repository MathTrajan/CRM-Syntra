# Banco de dados Neon PostgreSQL (JDBC)
# Formato: jdbc:postgresql://HOST/DB?sslmode=require&user=USER&password=PASS
DATABASE_URL=jdbc:postgresql://HOST.neon.tech/DBNAME?sslmode=require&user=USUARIO&password=SENHA

# Token secreto do webhook (gere uma string aleatoria longa)
WEBHOOK_SECRET=defina-um-token-aleatorio

# Integracao com fonte externa de leads (NAO commitar valores reais)
DIVIA_API_BASE_URL=
DIVIA_API_TOKEN=

# Credenciais iniciais do admin (so usadas no primeiro boot)
ADMIN_EMAIL=admin@syntra.com
ADMIN_PASSWORD=trocar-no-primeiro-login

# Porta HTTP (Railway define automaticamente)
PORT=8080
